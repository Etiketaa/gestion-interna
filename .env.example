# Variables de entorno para Railway
# Copiar este archivo como .env y completar los valores

# ─── Base de Datos ───────────────────────────────────
# Railway provee esta variable automáticamente al agregar PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/railway

# ─── Autenticación ───────────────────────────────────
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio_aqui

# ─── Usuarios del sistema ────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar_contraseña_segura

# ─── Servidor ────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Frontend (solo si usás Vercel separado) ─────────
# FRONTEND_URL=https://tu-app.vercel.app
